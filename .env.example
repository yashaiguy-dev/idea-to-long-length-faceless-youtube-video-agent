# === GATHOS (image generation) ===
GATHOS_API_KEY=img_live_your_image_key_here

# === GATHOS (text-to-speech) ===
GATHOS_TTS_API_KEY=tts_live_your_tts_key_here

# === DEEPGRAM (word-level timestamps) ===
DEEPGRAM_API_KEY=your_deepgram_key_here

# === YOUTUBE DIRECT UPLOAD (optional) ===
# If set, finished videos auto-upload to YouTube as private drafts.
# Get these from Google Cloud Console → OAuth 2.0 credentials.
# Leave blank to skip YouTube upload — videos still save locally.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
